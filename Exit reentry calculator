<script>
function fmt(n){return 'SAR '+n.toLocaleString('en-SA');}
function calcExit(){
  const t=document.getElementById('et').value;
  const d=parseInt(document.getElementById('ed').value);
  const deps=parseInt(document.getElementById('edeps').value)||0;
  const F={single:{1:200,3:400,6:400,12:400,24:400},multiple:{1:300,3:400,6:500,12:800,24:1200},final:{1:200,3:200,6:200,12:200,24:200}};
  const sf=F[t][d]||200;
  const df=deps*sf;
  const tot=sf+df;
  const TL={single:'Single Exit/Re-entry',multiple:'Multiple Exit/Re-entry',final:'Final Exit Visa'};
  document.getElementById('exit-tot').textContent=fmt(tot);
  document.getElementById('exit-sub').textContent=TL[t]+' — '+d+' month(s)';
  document.getElementById('er-type').textContent=TL[t];
  document.getElementById('er-spons').textContent=fmt(sf);
  document.getElementById('er-deps').textContent=deps>0?fmt(df)+' ('+deps+')':'None';
  document.getElementById('er-tot').textContent=fmt(tot);
  document.getElementById('exit-r').classList.add('show');
}
</script>
